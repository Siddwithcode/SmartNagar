# Copy to .env in the project root for docker compose:
#   cp .env.production.example .env

JWT_SECRET=replace_with_a_long_random_secret

# Public URL users open in the browser (same origin as nginx in docker compose)
CLIENT_URL=http://localhost
BACKEND_URL=http://localhost

# MongoDB Atlas (recommended for production) — override in docker-compose if using Atlas:
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/smartnagar

# Image storage (strongly recommended on cloud hosts)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI issue categorization
GEMINI_API_KEY=
